<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="MascotApp.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="설정" Width="380" Height="860"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

	<ScrollViewer>
		<StackPanel Margin="20">

			<!-- 이동 속도 -->
			<TextBlock Text="이동 속도" FontWeight="Bold" Margin="0,0,0,6"/>
			<Grid Margin="0,0,0,16">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="40"/>
				</Grid.ColumnDefinitions>
				<Slider x:Name="SpeedSlider"
                        Minimum="1" Maximum="10" Value="3"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        ValueChanged="OnSpeedChanged"/>
				<TextBlock x:Name="SpeedLabel" Grid.Column="1"
                           Text="3" TextAlignment="Center"
                           VerticalAlignment="Center"/>
			</Grid>

			<Separator Margin="0,0,0,16"/>

			<!-- 커스텀 이미지 -->
			<TextBlock Text="커스텀 이미지" FontWeight="Bold" Margin="0,0,0,12"/>

			<TextBlock Text="Idle" Margin="0,0,0,4"/>
			<Grid Margin="0,0,0,10">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="70"/>
				</Grid.ColumnDefinitions>
				<TextBox x:Name="IdlePath" IsReadOnly="True" Padding="4"/>
				<Button Grid.Column="1" Content="불러오기"
                        Margin="6,0,0,0" Click="OnLoadIdle"/>
			</Grid>

			<TextBlock Text="Walk" Margin="0,0,0,4"/>
			<Grid Margin="0,0,0,10">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="70"/>
				</Grid.ColumnDefinitions>
				<TextBox x:Name="WalkPath" IsReadOnly="True" Padding="4"/>
				<Button Grid.Column="1" Content="불러오기"
                        Margin="6,0,0,0" Click="OnLoadWalk"/>
			</Grid>

			<TextBlock Text="Pet" Margin="0,0,0,4"/>
			<Grid Margin="0,0,0,10">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="70"/>
				</Grid.ColumnDefinitions>
				<TextBox x:Name="PetPath" IsReadOnly="True" Padding="4"/>
				<Button Grid.Column="1" Content="불러오기"
                        Margin="6,0,0,0" Click="OnLoadPet"/>
			</Grid>

			<TextBlock Text="Drag" Margin="0,0,0,4"/>
			<Grid Margin="0,0,0,10">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="70"/>
				</Grid.ColumnDefinitions>
				<TextBox x:Name="DragPath" IsReadOnly="True" Padding="4"/>
				<Button Grid.Column="1" Content="불러오기"
                        Margin="6,0,0,0" Click="OnLoadDrag"/>
			</Grid>

			<Separator Margin="0,8,0,16"/>

			<!-- 하트 설정 -->
			<TextBlock Text="하트 설정" FontWeight="Bold" Margin="0,0,0,12"/>

			<TextBlock Text="스폰 범위 (좁음 ↔ 넓음)" Margin="0,0,0,4"/>
			<Grid Margin="0,0,0,10">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="40"/>
				</Grid.ColumnDefinitions>
				<Slider x:Name="HeartSpreadSlider"
                        Minimum="5" Maximum="100" Value="30"
                        TickFrequency="5" IsSnapToTickEnabled="True"
                        ValueChanged="OnHeartSpreadChanged"/>
				<TextBlock x:Name="HeartSpreadLabel" Grid.Column="1"
                           Text="30" TextAlignment="Center"
                           VerticalAlignment="Center"/>
			</Grid>

			<TextBlock Text="속도 (느림 ↔ 빠름)" Margin="0,0,0,4"/>
			<Grid Margin="0,0,0,10">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="40"/>
				</Grid.ColumnDefinitions>
				<Slider x:Name="HeartSpeedSlider"
                        Minimum="20" Maximum="200" Value="80"
                        TickFrequency="10" IsSnapToTickEnabled="True"
                        ValueChanged="OnHeartSpeedChanged"/>
				<TextBlock x:Name="HeartSpeedLabel" Grid.Column="1"
                           Text="80" TextAlignment="Center"
                           VerticalAlignment="Center"/>
			</Grid>

			<TextBlock Text="생성 간격 (많음 ↔ 적음)" Margin="0,0,0,4"/>
			<Grid Margin="0,0,0,10">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="40"/>
				</Grid.ColumnDefinitions>
				<Slider x:Name="HeartCooldownSlider"
                        Minimum="1" Maximum="20" Value="6"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        ValueChanged="OnHeartCooldownChanged"/>
				<TextBlock x:Name="HeartCooldownLabel" Grid.Column="1"
                           Text="0.6" TextAlignment="Center"
                           VerticalAlignment="Center"/>
			</Grid>

			<!-- 하트 스폰 피벗 -->
			<TextBlock Text="하트 스폰 위치" FontWeight="Bold" Margin="0,0,0,4"/>
			<TextBlock Text="캐릭터 위에서 클릭해서 위치를 지정하세요"
					   Foreground="Gray" FontSize="11" Margin="0,0,0,8"/>

			<!-- 일반 / 반전 방향 토글 -->
			<StackPanel Orientation="Horizontal" Margin="0,0,0,8">
				<RadioButton x:Name="PivotNormalBtn"
							 Content="▶  일반 방향"
							 IsChecked="True"
							 GroupName="PivotMode"
							 Checked="OnPivotModeChanged"
							 Margin="0,0,16,0"/>
				<RadioButton x:Name="PivotMirrorBtn"
							 Content="◀  반전 방향"
							 GroupName="PivotMode"
							 Checked="OnPivotModeChanged"/>
			</StackPanel>

			<Border BorderBrush="Gray" BorderThickness="1"
					Width="200" Height="200"
					HorizontalAlignment="Left"
					Margin="0,0,0,8">
				<Canvas x:Name="PivotCanvas"
						Width="200" Height="200"
						Background="Transparent"
						MouseDown="OnPivotCanvasClick"
						Cursor="Cross">
					<!-- 캐릭터 실루엣 배경 -->
					<Image x:Name="PivotPreviewImage"
						   Width="200" Height="200"
						   Stretch="Uniform"
						   Opacity="0.5"/>
					<!-- 일반 방향 마커 (빨강) -->
					<Ellipse x:Name="PivotMarker"
							 Width="12" Height="12"
							 Fill="Red"
							 Canvas.Left="94"
							 Canvas.Top="34"/>
					<!-- 반전 방향 마커 (파랑) -->
					<Ellipse x:Name="PivotMarkerMirrored"
							 Width="12" Height="12"
							 Fill="DodgerBlue"
							 Opacity="0.35"
							 Canvas.Left="94"
							 Canvas.Top="34"/>
				</Canvas>
			</Border>

			<!-- 범례 -->
			<StackPanel Orientation="Horizontal" Margin="0,0,0,16">
				<Ellipse Width="10" Height="10" Fill="Red"
						 Margin="0,0,4,0" VerticalAlignment="Center"/>
				<TextBlock Text="일반" FontSize="11" Margin="0,0,14,0"
						   VerticalAlignment="Center"/>
				<Ellipse Width="10" Height="10" Fill="DodgerBlue"
						 Margin="0,0,4,0" VerticalAlignment="Center"/>
				<TextBlock Text="반전" FontSize="11"
						   VerticalAlignment="Center"/>
			</StackPanel>

			<Separator Margin="0,0,0,16"/>

			<!-- 프리셋 -->
			<TextBlock Text="프리셋" FontWeight="Bold" Margin="0,0,0,8"/>
			<TextBlock Text="프리셋 이름" Margin="0,0,0,4"/>
			<Grid Margin="0,0,0,8">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="70"/>
					<ColumnDefinition Width="70"/>
				</Grid.ColumnDefinitions>
				<TextBox x:Name="PresetNameBox" Padding="4"/>
				<Button Grid.Column="1" Content="저장"
                        Margin="6,0,0,0" Click="OnSavePreset"/>
				<Button Grid.Column="2" Content="삭제"
                        Margin="6,0,0,0" Click="OnDeletePreset"/>
			</Grid>

			<ListBox x:Name="PresetList" Height="80"
                     SelectionChanged="OnPresetSelected"/>

			<Separator Margin="0,8,0,8"/>

			<!-- 적용 -->
			<Button Content="적용" Height="36"
                    Margin="0,4,0,0" Click="OnApply"/>

		</StackPanel>
	</ScrollViewer>
</Window>
